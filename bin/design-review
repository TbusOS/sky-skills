#!/usr/bin/env bash
# design-review — one-command wrapper for the design review pipeline
#
# Runs up to four gates:
#   [1/4] verify.py         — structural (placeholders, DOCTYPE, BEM, …)
#   [2/4] visual-audit.mjs  — rendered (contrast, brand-presence, italic,
#                             cross-skill-smell, …) — Playwright + pngjs
#   [3/4] screenshot.mjs    — full-page PNG for human review
#   [4/4] critic.mjs (opt)  — LLM taste judge; prepares prompt for
#                             a Claude (or other LLM) call
#
# Usage:
#   bin/design-review [flags] <html-path> [...]
#
# Flags:
#   --repo=<path>      Webroot for serving assets (Playwright gates). Defaults to CWD.
#                      Use this when running from outside sky-skills (e.g. against
#                      engram's docs/en/index.html — set --repo=/path/to/engram).
#   --skill=<name>     Force a skill: anthropic | apple | ember | sage | glass.
#                      If omitted, verify.py auto-detects from the HTML's <link>.
#   --theme=<t>        dark | light — forwarded to visual-audit + screenshot
#                      (flips html[data-theme] after load). With --skill=glass
#                      and no explicit --theme, gates 2 and 3 run BOTH themes
#                      automatically (dark is brand-canonical, light is the
#                      iOS-frost variant; both must be clean).
#   --css=<path>       Extra CSS file for class-definition lookup. Can repeat.
#   --strict           Treat visual-audit warnings as failure (default: only errors).
#   --internal         (alias --allow-monolingual) Forwarded to gate 1 verify.py:
#                      skip the bilingual-page rule for internal monolingual docs.
#                      Gates 2/3/4 unchanged — glass still auto-runs both themes.
#   --out=<dir>        Where to save screenshots (default: <repo>/shots/).
#   --critic           Also run the LLM critic (gate 4). Writes the critic prompt
#                      to <out>/critic-<basename>-<timestamp>.md. You then feed
#                      that to Claude / any LLM, or in Claude Code invoke the
#                      `design-critic` subagent with the target path.
#   --multi-critic     Like --critic, but uses 4 specialist subagents in parallel
#                      (composition/copy/illustration/brand) plus an aggregator.
#                      Writes 5 prompt files to <out>/multi-critic-*-<ts>.md.
#                      Each specialist scores only its axis in fresh context.
#   --learn            Harness component 07 · learning-loop. After you have
#                      verdict files in <out>/verdict-*.json (or multi-critic
#                      outputs), builds a design-learner prompt that proposes
#                      new known-bugs rows, visual-audit checks, and dos-and-donts
#                      entries. Proposes only — human applies.
#   --plan --skill=X --page=Y
#                      Planning mode — skip all gates, generate sprint-contract.md
#                      for an upcoming page generation.
#   --distill --skill=X --page=Y [--corpus=<dir>] [--out=<dir>]
#                      Harness component 08 · library-grower. Skip all gates and
#                      distill a candidate canonical from ≥5 successful
#                      same-type pages (all 4 gates passed, critic ≥ 88).
#                      --corpus defaults to corpus/<skill>/<page>/ under the
#                      sky-skills root. If the corpus holds fewer than 5 .html
#                      files, reports "insufficient samples" and exits 1
#                      instead of running. Output (candidate.md +
#                      provenance.json) is a DRAFT for human review — the
#                      grower proposes, it never ships into the canonical
#                      library by itself.
#   --audit            Audit mode — batch-check existing HTML (file or directory)
#                      with verify + visual-audit, no screenshot, do NOT exit on
#                      first error, aggregate results into one report.
#                      Pass-through flags: --skill, --out, --strict.
#                      Audit-only flags (forwarded to audit.mjs):
#                        --max=<n>             cap files audited
#                        --exclude=<csv>       dir names to skip
#                        --include=<substr>    filename filter (default ".html")
#                        --no-visual           verify-only (~10x faster)
#                        --allow-monolingual   skip bilingual rule
#                      Writes audit-report-<ts>.md + .json to --out.
#                      Examples:
#                        bin/design-review --audit docs/                  # whole dir
#                        bin/design-review --audit --skill=anthropic site/index.html
#                        bin/design-review --audit --no-visual my-wiki/   # verify-only batch
#                        bin/design-review --audit https://example.com/p  # remote URL
#   -h, --help         Print this help.
#
# Examples:
#   # full review of a new pricing page
#   bin/design-review --critic docs/my-new-pricing.html
#
#   # cross-repo review (engram docs against anthropic-design rules)
#   bin/design-review --repo=~/code/engram --skill=anthropic \
#     --css=docs/assets/app.css docs/en/index.html
#
#   # generate a contract before writing
#   bin/design-review --plan --skill=sage --page=landing > /tmp/contract.md

set -eu

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
SKY_ROOT="$(cd "$SELF_DIR/.." && pwd)"

REPO="$PWD"
SKILL=""
PAGE=""
THEME=""
STRICT=""
OUT_DIR=""
CRITIC=""
MULTI_CRITIC=""
LEARN=""
PLAN=""
DISTILL=""
CORPUS=""
AUDIT=""
INTERNAL=""
AUDIT_FORWARD=()
CSS_ARGS=()
HTMLS=()

for arg in "$@"; do
  case "$arg" in
    --repo=*)  REPO="${arg#--repo=}" ;;
    --skill=*) SKILL="${arg#--skill=}" ;;
    --page=*)  PAGE="${arg#--page=}" ;;
    --theme=*) THEME="${arg#--theme=}" ;;
    --css=*)   CSS_ARGS+=("$arg") ;;
    --strict)  STRICT=1 ;;
    --out=*)   OUT_DIR="${arg#--out=}" ;;
    --critic)       CRITIC=1 ;;
    --multi-critic) MULTI_CRITIC=1 ;;
    --learn)        LEARN=1 ;;
    --plan)    PLAN=1 ;;
    --distill) DISTILL=1 ;;
    --corpus=*) CORPUS="${arg#--corpus=}" ;;
    --audit)   AUDIT=1 ;;
    --internal|--allow-monolingual)
               INTERNAL=1
               AUDIT_FORWARD+=("$arg") ;;
    --max=*|--exclude=*|--include=*|--no-visual)
               AUDIT_FORWARD+=("$arg") ;;
    -h|--help)
      awk 'NR < 2 { next } /^set -eu/ { exit } { sub(/^# ?/, ""); print }' "$0"
      exit 0
      ;;
    --*)
      echo "unknown flag: $arg" >&2
      exit 2
      ;;
    *) HTMLS+=("$arg") ;;
  esac
done

# ---------- Planning mode (skip all gates, emit contract) ----------
if [ -n "$PLAN" ]; then
  if [ -z "$SKILL" ] || [ -z "$PAGE" ]; then
    echo "--plan requires both --skill=<name> and --page=<type>" >&2
    exit 2
  fi
  exec node "$SKY_ROOT/skills/design-review/scripts/sprint-contract.mjs" \
    "--skill=$SKILL" "--page=$PAGE"
fi

# ---------- Distill mode (component 08 · library-grower, skip all gates) ----------
if [ -n "$DISTILL" ]; then
  if [ -z "$SKILL" ] || [ -z "$PAGE" ]; then
    echo "--distill requires both --skill=<name> and --page=<type>" >&2
    exit 2
  fi
  [ -z "$CORPUS" ] && CORPUS="$SKY_ROOT/corpus/$SKILL/$PAGE"
  MIN_SAMPLES=5  # keep in sync with library-grower.mjs
  sample_count=0
  if [ -d "$CORPUS" ]; then
    sample_count="$(find "$CORPUS" -maxdepth 1 -name '*.html' | wc -l | tr -d ' ')"
  fi
  if [ "$sample_count" -lt "$MIN_SAMPLES" ]; then
    echo "✗ insufficient samples: $sample_count .html in $CORPUS (need ≥ $MIN_SAMPLES)" >&2
    echo "  library-grower distills from $MIN_SAMPLES+ successful same-type pages" >&2
    echo "  (each passed all 4 gates with critic ≥ 88). Collect more successful" >&2
    echo "  pages first, or point at another directory via --corpus=<dir>." >&2
    exit 1
  fi
  distill_args=("--skill=$SKILL" "--page=$PAGE" "--corpus=$CORPUS")
  [ -n "$OUT_DIR" ] && distill_args+=("--out=$OUT_DIR")
  exec node "$SKY_ROOT/skills/design-review/scripts/library-grower.mjs" "${distill_args[@]}"
fi

# ---------- Audit mode (batch verify + visual-audit, aggregate report) ----------
if [ -n "$AUDIT" ]; then
  if [ "${#HTMLS[@]}" -eq 0 ]; then
    echo "--audit requires a path argument (file or directory)" >&2
    exit 2
  fi
  AUDIT_TARGET="${HTMLS[0]}"
  if [ "${#HTMLS[@]}" -gt 1 ]; then
    echo "--audit takes exactly one path; got: ${HTMLS[*]}" >&2
    echo "(use --include / --exclude to scope what audit.mjs walks under that path)" >&2
    exit 2
  fi
  audit_args=("$AUDIT_TARGET")
  [ -n "$SKILL" ] && audit_args+=("--skill=$SKILL")
  [ -n "$REPO" ] && audit_args+=("--repo=$REPO")
  [ -n "$OUT_DIR" ] && audit_args+=("--out=$OUT_DIR")
  [ -n "$STRICT" ] && audit_args+=("--strict")
  for f in "${AUDIT_FORWARD[@]}"; do audit_args+=("$f"); done
  exec node "$SKY_ROOT/skills/design-review/scripts/audit.mjs" "${audit_args[@]}"
fi

if [ "${#HTMLS[@]}" -eq 0 ]; then
  echo "usage: bin/design-review [--critic] [--repo=<path>] [--skill=<name>] [--css=<path>]... <html> [...]" >&2
  echo "       bin/design-review --plan --skill=<name> --page=<type>" >&2
  echo "       bin/design-review --distill --skill=<name> --page=<type> [--corpus=<dir>]" >&2
  exit 2
fi

REPO="$(cd "$REPO" && pwd)"
[ -z "$OUT_DIR" ] && OUT_DIR="$REPO/shots"
mkdir -p "$OUT_DIR"

VERIFY="$SKY_ROOT/skills/design-review/scripts/verify.py"
VISUAL="$SKY_ROOT/skills/design-review/scripts/visual-audit.mjs"
SCREEN="$SKY_ROOT/skills/design-review/scripts/screenshot.mjs"
CRITIC_SCRIPT="$SKY_ROOT/skills/design-review/scripts/critic.mjs"
MULTI_CRITIC_SCRIPT="$SKY_ROOT/skills/design-review/scripts/multi-critic.mjs"
LEARN_SCRIPT="$SKY_ROOT/skills/design-review/scripts/learning-loop.mjs"

SKILL_FLAG=()
[ -n "$SKILL" ] && SKILL_FLAG=("--skill=$SKILL")

TOTAL_GATES=3
[ -n "$CRITIC" ] && TOTAL_GATES=4
[ -n "$MULTI_CRITIC" ] && TOTAL_GATES=4

CRITIC_MODE="no"
[ -n "$CRITIC" ] && CRITIC_MODE="solo"
[ -n "$MULTI_CRITIC" ] && CRITIC_MODE="multi (4 specialists)"

echo ""
echo "┌─ design-review · $(date +%Y-%m-%d\ %H:%M:%S)"
echo "│  repo=$REPO  skill=${SKILL:-auto}  strict=${STRICT:-no}  critic=$CRITIC_MODE"
echo "│  targets: ${HTMLS[*]}"
echo "└───────────────────────────────────────────────────────"
echo ""

# ---------- Gate 1 · structural ----------
# --internal forwards to verify.py only (skips the bilingual-page rule for
# internal monolingual docs); gates 2/3/4 behave identically either way, so
# glass pages still get the automatic dark+light double run.
VERIFY_FLAGS=()
[ -n "$INTERNAL" ] && VERIFY_FLAGS+=("--internal")
echo "━━ [1/$TOTAL_GATES] verify.py (structural)"
( cd "$REPO" && python3 "$VERIFY" "${SKILL_FLAG[@]}" "${VERIFY_FLAGS[@]}" "${CSS_ARGS[@]}" "${HTMLS[@]}" )

# ---------- Theme matrix ----------
# Default: one run, no theme override. Explicit --theme: that theme only.
# glass with no --theme: dark (brand-canonical) AND light (iOS-frost) — both
# must be clean before a glass page ships.
THEMES=("default")
if [ -n "$THEME" ]; then
  THEMES=("$THEME")
elif [ "$SKILL" = "glass" ]; then
  THEMES=("dark" "light")
fi

# ---------- Gate 2 · visual-audit ----------
exit_visual=0
for theme in "${THEMES[@]}"; do
  VISUAL_FLAGS=(--ignore-intentional)
  theme_label=""
  if [ "$theme" != "default" ]; then
    VISUAL_FLAGS+=("--theme=$theme")
    theme_label="  [theme=$theme]"
  fi
  for html in "${HTMLS[@]}"; do
    echo ""
    echo "━━ [2/$TOTAL_GATES] visual-audit.mjs (rendered + brand + italic + smell)  $html$theme_label"
    if ! ( cd "$REPO" && node "$VISUAL" "${VISUAL_FLAGS[@]}" "$html" ); then
      exit_visual=1
    fi
  done
done
if [ "$exit_visual" -ne 0 ]; then
  echo ""
  echo "✗ visual-audit produced errors — fix before continuing" >&2
  exit 1
fi

# ---------- Gate 3 · screenshot ----------
for theme in "${THEMES[@]}"; do
  SCREEN_FLAGS=()
  suffix=""
  if [ "$theme" != "default" ]; then
    SCREEN_FLAGS=("--theme=$theme")
    suffix="-$theme"
  fi
  for html in "${HTMLS[@]}"; do
    base="$(basename "$html" .html)"
    out="$OUT_DIR/${base}${suffix}-$(date +%Y%m%d-%H%M%S).png"
    echo ""
    echo "━━ [3/$TOTAL_GATES] screenshot.mjs    $html  →  $out"
    ( cd "$REPO" && node "$SCREEN" "${SCREEN_FLAGS[@]}" "$html" "$out" )
  done
done

# ---------- Gate 4 · design-critic (solo OR 4 specialists) ----------
if [ -n "$CRITIC" ]; then
  for html in "${HTMLS[@]}"; do
    base="$(basename "$html" .html)"
    critic_prompt="$OUT_DIR/critic-${base}-$(date +%Y%m%d-%H%M%S).md"
    echo ""
    echo "━━ [4/$TOTAL_GATES] critic.mjs (LLM taste — solo critic prompt)   $html"
    critic_args=("$html")
    [ -n "$SKILL" ] && critic_args+=("--skill=$SKILL")
    [ -n "$PAGE" ]  && critic_args+=("--page=$PAGE")
    critic_args+=("--out=$critic_prompt")
    if ( cd "$REPO" && node "$CRITIC_SCRIPT" "${critic_args[@]}" ); then
      echo "   prompt written → $critic_prompt"
      echo "   next: feed to Claude (or in Claude Code invoke 'design-critic' subagent)"
    else
      echo "   critic prompt prep FAILED — likely missing canonical for this skill/page" >&2
      exit 1
    fi
  done
fi

if [ -n "$MULTI_CRITIC" ]; then
  for html in "${HTMLS[@]}"; do
    echo ""
    echo "━━ [4/$TOTAL_GATES] multi-critic.mjs (4 specialists — composition/copy/illustration/brand)   $html"
    mc_args=("$html")
    [ -n "$SKILL" ] && mc_args+=("--skill=$SKILL")
    [ -n "$PAGE" ]  && mc_args+=("--page=$PAGE")
    mc_args+=("--out-dir=$OUT_DIR")
    if ! ( cd "$REPO" && node "$MULTI_CRITIC_SCRIPT" "${mc_args[@]}" >/dev/null ); then
      echo "   multi-critic prompt prep FAILED" >&2
      exit 1
    fi
    echo "   5 prompt files written (4 specialists + aggregator) in $OUT_DIR"
    echo "   next: in Claude Code, Task() each specialist prompt in parallel, then Task() the aggregator"
  done
fi

# ---------- Learning-loop (component 07) ----------
if [ -n "$LEARN" ]; then
  for html in "${HTMLS[@]}"; do
    echo ""
    echo "━━ [learn] learning-loop.mjs (propose known-bugs / check / dos-and-donts codifications)  $html"
    learn_args=(--verdicts-dir="$OUT_DIR" --target="$html")
    if ! ( cd "$REPO" && node "$LEARN_SCRIPT" "${learn_args[@]}" ); then
      echo "   learning-loop FAILED — probably no verdicts found in $OUT_DIR" >&2
      echo "   did you run --critic or --multi-critic first and save JSON verdicts?" >&2
      exit 1
    fi
    echo "   next: in Claude Code, Task(subagent_type='design-learner', prompt=file-contents)"
  done
fi

echo ""
echo "┌─ Summary"
echo "│  ✓ verify.py       (structural)"
echo "│  ✓ visual-audit    (rendered + brand + italic + smell)"
echo "│  ✓ screenshot      (in $OUT_DIR)"
[ -n "$CRITIC" ] && echo "│  ✓ critic prompt   (solo — feed to LLM)"
[ -n "$MULTI_CRITIC" ] && echo "│  ✓ multi-critic    (4 specialists + aggregator prompts)"
[ -n "$LEARN" ] && echo "│  ✓ learning-loop   (proposal prompt for known-bugs / check / dos-and-donts)"
echo "└───────────────────────────────────────────────────────"
echo ""
